# ─────────────────────────────────────────────
#  Vidhya Backend – Environment Variables
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── Server ──────────────────────────────────
PORT=5000
NODE_ENV=development

# ── MongoDB ─────────────────────────────────
# Local:   mongodb://localhost:27017/vidhya
# Atlas:   mongodb+srv://<user>:<pass>@cluster.mongodb.net/vidhya
MONGODB_URI=mongodb://localhost:27017/vidhya

# ── JWT ─────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ── Google OAuth (for social login validation) ──
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── File Uploads ─────────────────────────────
MAX_FILE_SIZE_MB=5
UPLOAD_PATH=src/uploads

# ── Rate Limiting ────────────────────────────
RATE_LIMIT_WINDOW_MINUTES=15
RATE_LIMIT_MAX_REQUESTS=100

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed origins
CLIENT_URL=http://localhost:3000
